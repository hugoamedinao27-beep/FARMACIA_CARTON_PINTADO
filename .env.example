# ============================================
# Backend — Variables de entorno (local)
# Copiar este archivo como .env y editar valores
# ============================================

# --- Base de Datos (formato individual) ---
DB_USER=root                 # Usuario de MySQL
DB_PASSWORD=Hamo1010            # Contraseña de MySQL
DB_NAME=farmacia_carton_pintado
DB_HOST=127.0.0.1
DB_PORT=3306

# --- Base de Datos (connection string, usado en Railway/producción) ---
# DATABASE_URL=mysql://usuario:password@host:3306/farmacia_carton_pintado

# --- Servidor Express ---
PORT=4000                    # Puerto del backend
NODE_ENV=development         # development | production
JWT_SECRET=cambiar_esta_clave_secreta  # Clave para firmar JWT
CORS_ORIGIN=http://localhost:5000       # Origen permitido para CORS (URL del front)

# ============================================
# Frontend — solo necesario para build de producción
# ============================================
# NUXT_PUBLIC_API_BASE=http://localhost:4000/api/v1
