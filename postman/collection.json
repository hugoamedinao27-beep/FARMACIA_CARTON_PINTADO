          }
        },
        {
          "name": "Venta - Sin Autenticación (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Error 401 - sin token en ventas', () => {",
                  "    pm.response.to.have.status(401);",
                  "    pm.response.to.have.jsonBody('error', true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": []\n}"
            },
            "url": {
              "raw": "{{base_url}}/ventas",
              "host": ["{{base_url}}"],
              "path": ["ventas"]
            }
          },
          "auth": {
            "type": "noauth"
          }
        }
      ]
    },
