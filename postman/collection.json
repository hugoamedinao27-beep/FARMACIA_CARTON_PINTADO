                  "    pm.response.to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ventas/historial",
              "host": ["{{base_url}}"],
              "path": ["ventas", "historial"]
